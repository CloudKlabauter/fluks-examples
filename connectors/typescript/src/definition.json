{
    "$schema": "https://docs.fluks.cloud/schemas/connector/draft-2/schema.json",
    "Infos": {
        "Version": "0.1.0",
        "ConnectorName": "Handwerker Beispiel",
        "ConnectorId": "ck.fluks.examples.connectors.tradesmen",
        "Description": "Beispiel-Connector für einen Handwerkerdienst"
    },
    "SecurityInfo": {
        "Name": "x-ck-api-token"
    },
    "Triggers": {
        "OrderCompleted": {
            "Name": "OrderCompleted",
            "ResultModelId": "OrderCompletedResult",
            "Title": "Auftrag abgeschlossen",
            "Description": "Ein Auftrag wurde abgeschlossen",
            "SchemaName": "ck.fluks.examples.connectors.tradesmen.ordercompleted",
            "SchemaVersion": "1",
            "TriggerEvaluationLocation": "Connector",
            "PossibleFilters": {
                "Static": {
                    "ClientId": {
                        "DataType": "string",
                        "Required": false,
                        "Description": "Kunden-ID"
                    }
                }
            }
        }
    },
    "Lookups": {},
    "Actions": {
        "CreateOrder": {
            "Name": "CreateOrder",
            "Title": "Neuen Auftrag erstellen",
            "Description": "Auftragsanfrage an den Handwerkerdienst senden",
            "ActionResultContentDefinitionName": "CreateOrderResponse",
            "SchemaName": "ck.fluks.examples.connectors.tradesmen.createorder",
            "SchemaVersion": "1",
            "Parameters": [
                {
                    "Name": "OrderText",
                    "Description": "Was erledigt werden soll",
                    "Type": "string",
                    "Required": true
                },
                {
                    "Name": "ClientAdress",
                    "Description": "Kundenadresse",
                    "Type": "string",
                    "Required": true
                }
            ]
        }
    },
    "Credentials": {},
    "ModelDefinitions": {
        "CreateOrderResponse": {
            "DataType": "object",
            "Properties": {
                "Id": {
                    "DataType": "string",
                    "Description": "Auftrags-ID"
                }
            }
        },
        "OrderCompletedResult": {
            "DataType": "object",
            "Properties": {
                "ClientID": {
                    "DataType": "string",
                    "Description": "Kunden-ID"
                },
                "Message": {
                    "DataType": "string",
                    "Description": "Zusätzliche Nachricht"
                }
            }
        }
    }
}
